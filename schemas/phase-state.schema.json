{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentic Brain Phase State",
  "type": "object",
  "required": ["phaseId", "status", "currentAgent", "agentSequence"],
  "properties": {
    "phaseId": { "type": "string", "minLength": 1 },
    "phaseName": { "type": "string" },
    "status": { "type": "string", "enum": ["not_started", "in_progress", "completed", "blocked"] },
    "currentAgent": { "type": "string", "minLength": 1 },
    "nextAgent": { "type": "string" },
    "agentSequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "status"],
        "properties": {
          "agent": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "blocked"] },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "build": { "type": "string" },
        "test": { "type": "string" },
        "lint": { "type": "string" },
        "evidence": { "type": "string" }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
