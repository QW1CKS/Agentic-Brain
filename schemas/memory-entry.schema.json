{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentic Brain Memory Entry",
  "type": "object",
  "required": ["id", "timestamp", "entryType", "summary"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "entryType": {
      "type": "string",
      "enum": ["decision", "learning", "action", "blocker", "handoff"]
    },
    "agent": { "type": "string" },
    "phase": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["active", "resolved", "deprecated"]
    }
  }
}
